-- ══════════════════════════════════════════════════════
--  DELIBREADS · Panel CEO · Tablas en Supabase
--  Copia y pega esto en Supabase > SQL Editor > New query
-- ══════════════════════════════════════════════════════

-- Tabla: TO DOs
create table if not exists todos (
  id          bigint primary key,
  titulo      text not null,
  descripcion text,
  prioridad   text default 'media',
  fecha       text,
  proyecto    text,
  scope       text default 'laboral',
  asignado    text default 'AO',
  completado  boolean default false,
  creado_en   text
);

-- Tabla: Emails pendientes
create table if not exists emails (
  id                 bigint primary key,
  remitente          text,
  asunto             text,
  resumen            text,
  accion             text,
  respuesta_sugerida text,
  prioridad          text default 'media',
  fecha_recibido     text,
  proyecto           text,
  scope              text default 'laboral',
  contestado         boolean default false,
  creado_en          text
);

-- Tabla: Temas pendientes
create table if not exists temas (
  id                bigint primary key,
  titulo            text not null,
  descripcion       text,
  pendiente_de      text,
  proyecto          text,
  fecha_seguimiento text,
  estado            text default 'en_espera',
  scope             text default 'laboral',
  creado_en         text
);

-- Tabla: Notas (una sola fila con id='panel')
create table if not exists notas (
  id        text primary key,
  contenido text
);

-- ── Permisos: permitir acceso público (sin login) ──
-- Esto es necesario para que el HTML pueda leer y escribir sin autenticación
alter table todos  enable row level security;
alter table emails enable row level security;
alter table temas  enable row level security;
alter table notas  enable row level security;

create policy "acceso_publico_todos"  on todos  for all using (true) with check (true);
create policy "acceso_publico_emails" on emails for all using (true) with check (true);
create policy "acceso_publico_temas"  on temas  for all using (true) with check (true);
create policy "acceso_publico_notas"  on notas  for all using (true) with check (true);
